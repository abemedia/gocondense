package main

// import
import "fmt"

// aliased import
import f "fmt"

// var
var message = "hello"

// typed var
var name string = "test"

// multi-value var
var x, y = 1, 2

// typed multi-value var
var a, b int = 1, 2

// const
const pi = 3.14

// typed const
const version string = "1.0"

// multi-value const
const X, Y = 1, 2

// typed multi-value const
const A, B string = "a", "b"

// type
type UserID int

// type alias
type StringAlias = string
