package main

type Person struct {
	Name string
	Age  int
}

// Empty literal - no-op.
func empty() {
	p := Person{}
	println(p.Name)
}

// Comment in elements - leave untouched.
func commentInElements() {
	p := Person{Name: "John", // first name
		Age: 30,
	}
	println(p.Name)
}

// Keyed: first element on own line - leave untouched.
func keyed() {
	p := Person{
		Name: "John",
		Age:  30,
	}
	println(p.Name)
}

// Keyed: first element on same line - condense.
func keyedSameLine() {
	p := Person{Name: "John", Age: 30}
	println(p.Name)
}

// Unkeyed: always condense.
func unkeyed() {
	p := Person{"John", 30}
	println(p.Name)
}

// Anonymous struct: keyed, first element on own line - leave untouched.
func anonymousKeyed() {
	p := struct{ A, B string }{
		A: "x",
		B: "y",
	}
	println(p.A)
}

// Anonymous struct: keyed, first element on same line - condense.
func anonymousKeyedSameLine() {
	p := struct{ A, B string }{A: "x", B: "y"}
	println(p.A)
}

// Anonymous struct: unkeyed - condense.
func anonymousUnkeyed() {
	p := struct{ A, B string }{"x", "y"}
	println(p.A)
}

// Anonymous struct: multi-line type, first element on same line - leave untouched.
func anonymousMultiLineTypeSameLine() {
	p := struct {
		Name string
		Age  int
	}{Name: "John",
		Age: 30,
	}
	println(p.Name)
}

// Anonymous struct: multi-line type - leave untouched.
func anonymousMultiLineType() {
	p := struct {
		Name string
		Age  int
	}{
		"John",
		30,
	}
	println(p.Name)
}
