package main

// Top-level expression
var _ = x

func main() {
	// Expressions
	_ = variable
	_ = a + b
	_ = T{}
	_ = !value
	_ = a + (b * c) - d
	_ = (a + b) * c
	_ = a * (b + c)
	_ = -(x + y)

	// Type conversions
	_ = string("foo")
	_ = (*string)(nil)
	_ = (chan int)(nil)
	_ = (func())(nil)

	// Pointer dereference
	_ = *x
	_ = (*x).field
	_ = (*x)[0]
	_ = (*x)[0:1]
	_ = (*x).(T)

	// Binary/unary in single-value contexts
	var _ = a + b
	_ = []any{a + b}
	_ = map[any]any{0: a + b}
	switch {
	case a || b:
	}

	// Binary/unary in multi-value and key contexts
	_, _ = (a + b), c
	_ = []any{(a + b), c}
	_ = map[any]any{(a + b): 0}
	switch {
	case (a || b), c:
	}

	// Composite literals in control flow headers
	type T struct{ i int }
	if (T{}.i) == 0 {
	}
	if (T{}) == (T{}) {
	}
	if x := (T{}); x.i == 0 {
	}
	for (T{}.i) > 0 {
	}
	switch (T{}.i) {
	}

	// Control flow headers with hidden composite literals
	if f(T{}) {
	}
	if m[T{}] {
	}
	if x[T{}:] {
	}

	// Composite literal in unary/binary expr inside control flow init
	if x := (&T{}); x.i == 0 {
	}
	if x := (-T{}.i); x == 0 {
	}
	if x := (T{}.i + 1); x == 0 {
	}

	// Control flow headers without composite literals
	if x.(T) {
	}
	if *x {
	}
	if x == 0 {
	}
}

// Return statements
func returnSingle() any       { return a + b }
func returnMulti() (any, any) { return (a + b), c }
